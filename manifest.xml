<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>399bd8ea-ebf6-4d3a-b838-d2e4deaac2f3</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Contoso</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="My Office Add-in"/>
  <Description DefaultValue="A template to get started."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://www.contoso.com/help"/>
  <AppDomains>
    <AppDomain>https://www.contoso.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
                    <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="MyAddInTab">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="ToolsIcon.16x16"/>
                  <bt:Image size="32" resid="ToolsIcon.32x32"/>
                  <bt:Image size="80" resid="ToolsIcon.80x80"/>
                </Icon>
<Control xsi:type="Button" id="ConcatenateButton">
                  <Label resid="ConcatenateButton.Label"/>
                  <Supertip>
                    <Title resid="ConcatenateButton.Label"/>
                    <Description resid="ConcatenateButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="ConcatIcon.16x16"/>
                    <bt:Image size="32" resid="ConcatIcon.32x32"/>
                    <bt:Image size="80" resid="ConcatIcon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ConcatTaskpaneId</TaskpaneId>
                    <SourceLocation resid="ConcatTaskpane.Url"/>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="ImportCsvButton">
                  <Label resid="ImportCsvButton.Label"/>
                  <Supertip>
                    <Title resid="ImportCsvButton.Label"/>
                    <Description resid="ImportCsvButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="ImportIcon.16x16"/>
                    <bt:Image size="32" resid="ImportIcon.32x32"/>
                    <bt:Image size="80" resid="ImportIcon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>CSVImportTaskpaneId</TaskpaneId>
                    <SourceLocation resid="CSVImportTaskpane.Url"/>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="EnhancedVlookupButton">
                  <Label resid="EnhancedVlookupButton.Label"/>
                  <Supertip>
                    <Title resid="EnhancedVlookupButton.Label"/>
                    <Description resid="EnhancedVlookupButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="LookupIcon.16x16"/>
                    <bt:Image size="32" resid="LookupIcon.32x32"/>
                    <bt:Image size="80" resid="LookupIcon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>VlookupTaskpaneId</TaskpaneId>
                    <SourceLocation resid="VlookupTaskpane.Url"/>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="FillSeriesButton">
                  <Label resid="FillSeriesLabel"/>
                  <Supertip>
                    <Title resid="FillSeriesLabel"/>
                    <Description resid="FillSeriesTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="FillSeriesIcon.16x16"/>
                    <bt:Image size="32" resid="FillSeriesIcon.32x32"/>
                    <bt:Image size="80" resid="FillSeriesIcon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>FillSeriesTaskpaneId</TaskpaneId><SourceLocation resid="FillSeriesTaskpane.Url"/></Action>
                </Control>
              </Group>
              <Label resid="CustomTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/icon-80.png"/>
        <bt:Image id="ToolsIcon.16x16" DefaultValue="https://localhost:3000/assets/tools-16.png"/>
        <bt:Image id="ToolsIcon.32x32" DefaultValue="https://localhost:3000/assets/tools-32.png"/>
        <bt:Image id="ToolsIcon.80x80" DefaultValue="https://localhost:3000/assets/tools-80.png"/>
        <bt:Image id="ConcatIcon.16x16" DefaultValue="https://localhost:3000/assets/concat-16.png"/>
        <bt:Image id="ConcatIcon.32x32" DefaultValue="https://localhost:3000/assets/concat-32.png"/>
        <bt:Image id="ConcatIcon.80x80" DefaultValue="https://localhost:3000/assets/concat-80.png"/>
        <bt:Image id="ImportIcon.16x16" DefaultValue="https://localhost:3000/assets/import-16.png"/>
        <bt:Image id="ImportIcon.32x32" DefaultValue="https://localhost:3000/assets/import-32.png"/>
        <bt:Image id="ImportIcon.80x80" DefaultValue="https://localhost:3000/assets/import-80.png"/>
        <bt:Image id="LookupIcon.16x16" DefaultValue="https://localhost:3000/assets/lookup-16.png"/>
        <bt:Image id="LookupIcon.32x32" DefaultValue="https://localhost:3000/assets/lookup-32.png"/>
        <bt:Image id="LookupIcon.80x80" DefaultValue="https://localhost:3000/assets/lookup-80.png"/>
        <bt:Image id="FillSeriesIcon.16x16" DefaultValue="https://localhost:3000/assets/fill-series-16.png"/>
        <bt:Image id="FillSeriesIcon.32x32" DefaultValue="https://localhost:3000/assets/fill-series-32.png"/>
        <bt:Image id="FillSeriesIcon.80x80" DefaultValue="https://localhost:3000/assets/fill-series-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://localhost:3000/commands.html"/>
        <bt:Url id="ConcatTaskpane.Url" DefaultValue="https://localhost:3000/concat-taskpane.html"/>
        <bt:Url id="CSVImportTaskpane.Url" DefaultValue="https://localhost:3000/csv-import-taskpane.html"/>
        <bt:Url id="VlookupTaskpane.Url" DefaultValue="https://localhost:3000/vlookup-taskpane.html"/>
        <bt:Url id="FillSeriesTaskpane.Url" DefaultValue="https://localhost:3000/fill-series-taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="CustomTab.Label" DefaultValue="我的工具"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="Commands Group"/>
        <bt:String id="ConcatenateButton.Label" DefaultValue="连接列"/>
        <bt:String id="ImportCsvButton.Label" DefaultValue="导入CSV"/>
        <bt:String id="EnhancedVlookupButton.Label" DefaultValue="增强查找"/>
        <bt:String id="FillSeriesLabel" DefaultValue="填充序列"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ConcatenateButton.Tooltip" DefaultValue="选中两列后点击，将数据用连接符合并到新列"/>
        <bt:String id="ImportCsvButton.Tooltip" DefaultValue="用 UTF-8 编码正确导入 CSV/文本文件，支持自定义分隔符"/>
        <bt:String id="EnhancedVlookupButton.Tooltip" DefaultValue="增强版查找功能：一次配置完成多列 INDEX/MATCH 查找，匹配列可在任意位置"/>
        <bt:String id="FillSeriesTooltip" DefaultValue="打开填充序列工具面板"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>